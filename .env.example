# Copy this to .env.local and fill in your values
# These are also set in Vercel dashboard under Project Settings > Environment Variables

# Set this to your chosen admin password
ADMIN_PASSWORD=roster123

# These are auto-filled by Vercel when you add a KV store — do not set manually
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
